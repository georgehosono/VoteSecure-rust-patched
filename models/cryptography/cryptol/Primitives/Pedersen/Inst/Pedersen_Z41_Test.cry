/**
 * Smoke test of k-Pedersen Commitments in the context
 * of the additive group of integers modulo 41 (ℤ/41ℤ)
 *
 * @author Frank Zeyda (frank.zeyda@freeandfair.us)
 * @copyright Free & Fair 2025-26
 * @version 0.1
 */
module Primitives::Pedersen::Inst::Pedersen_Z41_Test where

import Primitives::Pedersen::Inst::Pedersen_Z41

/**
 * Smoke test creating and opening a k-Pedersen commitment for
 * five messages.
 *
 * @note We use a seed of 0 for random number generation.
 */
main : Bit
main = create_and_open 0 tv
  where tv = [0, 1, 2, 5, 31]


/**
 * Smoke test creating and opening a k-Pedersen commitment for
 * five messages while producing additional trace output.
 *
 * @note We use a seed of 0 for random number generation.
 */
main'trace : Bit
main'trace = create_and_open'trace 0 tv
  where tv = [0, 1, 2, 5, 31]
